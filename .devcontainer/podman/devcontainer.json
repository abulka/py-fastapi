{
	"name": "Python 3 FastAPI (Podman)",
	"image": "mcr.microsoft.com/devcontainers/python:3.13",
	"containerEnv": {
		"PIP_USER": "true"
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-python.python",
				"ms-python.vscode-pylint",
				"ms-python.debugpy"
			]
		}
	},
	"forwardPorts": [8000],
	"postCreateCommand": "pip install --user -r requirements.txt",
	"remoteUser": "vscode",
	// Podman-specific args — do not use in the Docker variant:
	// --userns=keep-id  : maps the host user's UID/GID into the container so file
	//                     ownership works correctly. This value is Podman-specific;
	//                     Docker does not recognise it and will error.
	// label=disable     : disables SELinux label confinement for this container,
	//                     required on Fedora Silverblue / SELinux-enforcing hosts.
	//                     Docker tolerates the flag but it is meaningless outside
	//                     an SELinux-enforcing environment.
	"runArgs": [
		"--userns=keep-id",
		"--security-opt", "label=disable"
	],
	// "postStartCommand": "/home/vscode/.local/bin/uvicorn app.main:app --reload --host 0.0.0.0"
}
